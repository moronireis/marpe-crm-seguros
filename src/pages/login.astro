---
import '../styles/global.css';
export const prerender = false;
---
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Marpe CRM</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Fundo ambiente -->
  <div class="ambient" aria-hidden="true">
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
    <div class="orb orb-c"></div>
    <div class="grain"></div>
  </div>

  <div class="login-page">
    <div class="login-card glass-modal anim" style="--i:0">
      <div class="brand-logo anim" style="--i:1">M</div>
      <h1 class="brand-title anim" style="--i:2">Marpe CRM</h1>
      <p class="brand-sub anim" style="--i:3">Marca Corretora de Seguros</p>

      <form id="loginForm">
        <div class="field-block anim" style="--i:4">
          <label for="email">E-mail</label>
          <div class="input-wrap">
            <svg class="input-icon" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input type="email" id="email" name="email" required placeholder="seu@email.com" autocomplete="email" />
          </div>
        </div>

        <div class="field-block anim" style="--i:5">
          <label for="password">Senha</label>
          <div class="input-wrap">
            <svg class="input-icon" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input type="password" id="password" name="password" required placeholder="Sua senha" autocomplete="current-password" />
            <button type="button" class="toggle-pw" onclick="togglePassword()" title="Mostrar senha">
              <svg id="eyeIcon" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <label class="remember-row anim" style="--i:6">
          <input type="checkbox" id="rememberMe" name="remember" />
          <span>Lembrar este dispositivo por 90 dias</span>
        </label>

        <button type="submit" class="submit-btn anim" id="submitBtn" style="--i:7">
          <span id="btnText">Entrar</span>
          <svg id="btnSpinner" class="spinner hidden" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31.4" stroke-dashoffset="10"><animateTransform attributeName="transform" type="rotate" dur="0.8s" from="0 12 12" to="360 12 12" repeatCount="indefinite"/></circle></svg>
        </button>

        <p id="errorMsg" class="error-msg" aria-live="polite"></p>
      </form>

      <div class="login-foot anim" style="--i:8">WhatsApp, CRM e automações em um só lugar · u4digital</div>
    </div>
  </div>

  <script>
    function togglePassword() {
      const pw = document.getElementById('password') as HTMLInputElement;
      const icon = document.getElementById('eyeIcon') as unknown as SVGElement;
      const isPassword = pw.type === 'password';
      pw.type = isPassword ? 'text' : 'password';
      if (isPassword) {
        // Eye-slash icon (password visible)
        icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
      } else {
        // Eye icon (password hidden)
        icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
      }
    }

    const form = document.getElementById('loginForm') as HTMLFormElement;
    const errorMsg = document.getElementById('errorMsg') as HTMLParagraphElement;
    const btnText = document.getElementById('btnText') as HTMLSpanElement;
    const btnSpinner = document.getElementById('btnSpinner') as SVGElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.textContent = '';
      btnText.textContent = 'Entrando...';
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      const formData = new FormData(form);
      try {
        const rememberEl = document.getElementById('rememberMe') as HTMLInputElement;
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: formData.get('email'),
            password: formData.get('password'),
            remember: rememberEl?.checked ?? false,
          }),
        });
        const data = await res.json();
        if (res.ok) {
          window.location.href = '/inbox';
        } else {
          errorMsg.textContent = data.error || 'Falha no login.';
        }
      } catch {
        errorMsg.textContent = 'Erro de conexão. Tente novamente.';
      }
      btnText.textContent = 'Entrar';
      btnSpinner.classList.add('hidden');
      submitBtn.disabled = false;
    });
  </script>
</body>

<style>
  .login-page {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100vh;
    overflow: hidden;
    padding: 20px;
  }

  .login-card {
    width: min(400px, 100%);
    border-radius: var(--radius-xl);
    padding: 38px 34px 28px;
    display: flex;
    flex-direction: column;
  }

  .brand-logo {
    width: 52px;
    height: 52px;
    border-radius: 16px;
    background: linear-gradient(145deg, #4F9BFF, #1D5EDB);
    box-shadow: 0 8px 30px var(--accent-glow), 0 0 0 1px rgba(255,255,255,0.14) inset;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 21px;
    color: #fff;
    margin: 0 auto 18px;
  }
  .brand-title {
    text-align: center;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }
  .brand-sub {
    text-align: center;
    font-size: 12.5px;
    color: var(--text-secondary);
    margin: 4px 0 26px;
  }

  .field-block {
    margin-bottom: 16px;
  }
  .field-block label {
    display: block;
    font-size: 10px;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 6px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }
  .input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .input-icon {
    position: absolute;
    left: 14px;
    width: 15px;
    height: 15px;
    stroke: var(--text-muted);
    fill: none;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
    pointer-events: none;
  }
  .field-block input {
    width: 100%;
    padding: 11px 14px 11px 40px;
    background: var(--field-bg);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-size: 13.5px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out), background 0.2s var(--ease-out);
  }
  .field-block input::placeholder {
    color: var(--text-muted);
  }
  .field-block input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-dim);
  }

  .toggle-pw {
    position: absolute;
    right: 12px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
  }
  .toggle-pw svg {
    width: 16px;
    height: 16px;
    stroke: var(--text-muted);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: stroke 0.2s var(--ease-out);
  }
  .toggle-pw:hover svg {
    stroke: var(--text-secondary);
  }

  .remember-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    cursor: pointer;
    font-size: 12.5px;
    color: var(--text-muted);
    user-select: none;
  }
  .remember-row input[type="checkbox"] {
    width: 15px;
    height: 15px;
    accent-color: var(--accent);
    cursor: pointer;
    flex-shrink: 0;
  }

  .submit-btn {
    width: 100%;
    padding: 12px;
    margin-top: 14px;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255,255,255,0.18);
    background: linear-gradient(180deg, #4F8FF7, #2E6BE6);
    box-shadow: 0 3px 14px var(--accent-glow), inset 0 1px 0 rgba(255,255,255,0.28);
    color: #fff;
    font-size: 13.5px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: box-shadow 0.22s var(--ease-out), transform 0.22s var(--ease-spring), background 0.22s var(--ease-out);
  }
  .submit-btn:hover {
    background: linear-gradient(180deg, #5C99FF, #3575F0);
    box-shadow: 0 6px 22px var(--accent-glow), inset 0 1px 0 rgba(255,255,255,0.3);
    transform: translateY(-1px);
  }
  .submit-btn:active {
    transform: scale(0.98);
  }
  .submit-btn:disabled {
    opacity: 0.7;
    cursor: default;
    transform: none;
  }

  .spinner {
    width: 18px;
    height: 18px;
  }
  .hidden {
    display: none;
  }

  .error-msg {
    font-size: 12.5px;
    color: var(--red);
    text-align: center;
    margin-top: 14px;
    min-height: 18px;
  }

  .login-foot {
    text-align: center;
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--hairline);
  }
</style>
</html>
